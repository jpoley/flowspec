{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "version": 2,
  "final_space": true,
  "console_title_template": "{{ .Shell }} in {{ .Folder }}",
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "type": "os",
          "style": "powerline",
          "powerline_symbol": "\ue0b0",
          "foreground": "#ffffff",
          "background": "#d75f00",
          "template": " {{ if .WSL }}WSL at {{ end }}{{.Icon}} "
        },
        {
          "type": "git",
          "style": "powerline",
          "powerline_symbol": "\ue0b0",
          "foreground": "#ffffff",
          "background": "#d75f00",
          "template": " \ue0a0 {{ .HEAD }}{{ if .Working.Changed }} *{{ end }}{{ if .Staging.Changed }} +{{ end }} ",
          "properties": {
            "fetch_status": true
          }
        },
        {
          "type": "path",
          "style": "powerline",
          "powerline_symbol": "\ue0b0",
          "foreground": "#ffffff",
          "background": "#0077c2",
          "template": " \ue5ff {{ .Path }} ",
          "properties": {
            "style": "full"
          }
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "right",
      "segments": [
        {
          "type": "status",
          "style": "diamond",
          "leading_diamond": "\ue0b2",
          "trailing_diamond": "",
          "foreground": "#ffffff",
          "background": "#d75f00",
          "background_templates": [
            "{{ if eq .Code 0 }}#0077c2{{ end }}"
          ],
          "template": " {{ if eq .Code 0 }}\u2714{{ else }}\u2718 {{ .Code }}{{ end }} ",
          "properties": {
            "always_enabled": true
          }
        },
        {
          "type": "session",
          "style": "powerline",
          "powerline_symbol": "\ue0b2",
          "invert_powerline": true,
          "foreground": "#ffffff",
          "background": "#d75f00",
          "template": " {{ .HostName }} "
        },
        {
          "type": "time",
          "style": "powerline",
          "powerline_symbol": "\ue0b2",
          "invert_powerline": true,
          "foreground": "#ffffff",
          "background": "#0077c2",
          "template": " {{ .CurrentDate | date \"15:04:05\" }} "
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "type": "text",
          "style": "plain",
          "foreground": "#d75f00",
          "template": "\u276f "
        }
      ]
    }
  ]
}
